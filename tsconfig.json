{
	"compilerOptions": {
		"moduleResolution": "bundler",
		"module": "esnext",
		"target": "esnext",
		"lib": ["esnext", "DOM", "DOM.Iterable"],
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"resolveJsonModule": true
	},
	"include": [
		"ambient.d.ts",
		"*.ts",
		"*.svelte",
		"src/**/*.js",
		"src/**/*.ts",
		"src/**/*.svelte"
	]
}
