{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true
	},
	"include": [
		"ambient.d.ts",
		"*.ts",
		"*.svelte",
		"src/**/*.js",
		"src/**/*.ts",
		"src/**/*.svelte",
		"vite.config.ts"
	]
}
